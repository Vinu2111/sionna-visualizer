# ─── Sionna Visualizer Environment Variables ────────────
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to Git

# ─── Database ────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sionna_visualizer
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password

# ─── JWT Authentication ─────────────────────────────────
# Generate a strong random string (64+ characters)
JWT_SECRET=your_very_long_random_jwt_secret_key_minimum_64_characters
JWT_EXPIRATION=86400000

# ─── Python Bridge ───────────────────────────────────────
PYTHON_BRIDGE_URL=http://localhost:8001/simulate/demo

# ─── AI Integration ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── CORS ────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=http://localhost:4200

# ─── Railway Deployment (set in Railway dashboard) ───────
# RAILWAY_ENVIRONMENT=production
